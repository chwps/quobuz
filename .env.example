# Quobuz Playlist Downloader — Environment Configuration
# Copy this file to .env and fill in your values.
#
# NOTE: Most settings can be configured via the WebUI at http://localhost:3420
# Only SYNC_SCHEDULE is truly env-only. Everything else has WebUI controls.

# Server port (default: 3420)
PORT=3420

# Data directory inside container (default: /app/quobuz_data)
DATA_DIR=/app/quobuz_data

# Music output directory — mounted to ~/Music/Qobuz via volume
OUTPUT_DIR=/music

# Cron schedule for auto-sync (default: every 6 hours)
# Format: minute hour day month day_of_week
# Examples:
#   "0 */6 * * *"  — Every 6 hours
#   "0 3 * * *"    — Daily at 3 AM
#   "0 2 */2 * *"  — Every 2 days at 2 AM
SYNC_SCHEDULE="0 */6 * * *"

# Log level (default: INFO)
LOG_LEVEL=INFO

# ─── Optional: Pre-fill credentials (can also set via WebUI) ───

# Your Qobuz account email
# QOBUZ_EMAIL=your@email.com

# Your Qobuz account password
# QOBUZ_PASSWORD=your_password

# Qobuz App ID (auto-extracted via WebUI, or set manually)
# QOBUZ_APP_ID=

# Qobuz App Secret (auto-extracted via WebUI, or set manually)
# QOBUZ_APP_SECRET=

# Download quality: 5=MP3 320, 6=FLAC CD, 7=FLAC Hi-Res, 27=FLAC Hi-Res Ultra
# QOBUZ_QUALITY=6
