# Qobuz Email (WebUI or env)
QOBUZ_EMAIL=
QOBUZ_PASSWORD=

# Qobuz App credentials (auto-extracted by default)
QOBUZ_APP_ID=
QOBUZ_APP_SECRET=

# Audio quality: 5=MP3 320 | 6=FLAC CD | 7=FLAC Hi-Res | 27=FLAC Hi-Res Ultra
QOBUZ_QUALITY=6

# Download output directory (inside container)
OUTPUT_DIR=/app/Music/Qobuz

# Application data directory (inside container)
DATA_DIR=/app/quobuz_data

# Sync schedule (cron expression) - only ENV that matters for sync timing
SYNC_SCHEDULE=0 */6 * * *

# API key (optional - leave empty for no auth)
API_KEY=

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
